  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map(name: "blog")
}

model ContactUs {
  id          String   @id @unique @default(uuid())
  fullName    String
  email       String
  country     String
  phoneNumber String
  reason      String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map(name: "contact_us")
}

model InternOtps {
  id                      String    @id @unique @default(uuid())
  mobileNumber            String    @unique
  countryCode             String
  otp                     String
  otpExpiry               DateTime
  isVerifies              Boolean   @default(false)
  otpVerifyAttempts       Int       @default(0)
  otpVerifyBlockedUntil   DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@map(name: "intern_otps")
}

enum InterViewType {
  ONLINE
  OFFLINE
}

model Interview {
  id                    String        @id @unique @default(uuid())
  candidateManagementId String
  companyId             String
  jobId                 String
  internId              String
  interviewType         InterViewType @default(OFFLINE)
  interviewDate         String
  interviewTime         String
  interviewLink         String?
  interviewLocation     String?
  interviewStatus       String?
  rejectReason          String?

  company             Company             @relation(fields: [companyId], references: [id])
  job                 Job                 @relation(fields: [jobId], references: [id])
  intern              Interns             @relation(fields: [internId], references: [id])
  candidateManagement CandidateManagement @relation(fields: [candidateManagementId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map(name: "interview")
}


// ==================== ai interview =========================

enum AIInterviewType {
  COMPANY
  PRACTICE
}

enum AIInterviewStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AIInterviewerPreference {
  MALE
  FEMALE
}

enum AIInterviewCategory {
  BEHAVIORAL
  TECHNICAL
  CASE_STUDY
  SYSTEM_DESIGN
  CODING_DSA
  HR_CULTURE_FIT
  PROJECT_DEEP_DIVE
  RESUME_BASED
  DEBUGGING
  MIXED
}

enum ExpressionEmotion {
  CONFIDENT
  NERVOUS
  NEUTRAL
  HAPPY
  CONFUSED
}




model InternSubscriptionPlan {
  id               String   @id @unique @default(uuid())
  planName         String
  description      String
  price            Int
  discountedPrice  Int
  interviewCredits Int      // how many AI interviews this plan gives
  duration         Int      // plan validity in days
  features         Json
  isPopular        Boolean  @default(false)
  isDelete         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  internSubscriptions InternSubscription[]

  @@map(name: "intern_subscription_plans")
}

model InternSubscription {
  id                       String   @id @unique @default(uuid())
  internId                 String
  planId                   String
  interviewCreditsTotal    Int
  interviewCreditsRemaining Int
  subscriptionStart        DateTime @default(now())
  subscriptionEnd          DateTime
  isActive                 Boolean  @default(true)
  amountPaid               Int
  razorpay_order_id        String?
  razorpay_payment_id      String?
  razorpay_signature       String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  intern Interns                @relation(fields: [internId], references: [id])
  plan   InternSubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([internId, isActive])
  @@map(name: "intern_subscriptions")
}


model AIInterview {
  id                    String                   @id @unique @default(uuid())
  internId              String
  type                  AIInterviewType
  interviewerPreference AIInterviewerPreference  @default(MALE)
  interviewCategory     AIInterviewCategory      @default(MIXED)
  identityVerification  Boolean                  @default(false)
  duration              Int                      // planned duration in mins
  jobDescription        String?                  // only for COMPANY type
  companyWebsite        String?                  // only for COMPANY type
  additionalContext     String?
  resumeSnapshot        String                   // extracted resume text at session start
  status                AIInterviewStatus        @default(SETUP)

  // X AI System Configuration
  voiceUsed             String                   @default("eve")  // eve or rex
  vadThreshold          Float                    @default(0.5)
  silenceDuration       Int                      @default(700) // ms
  
  // Results — populated on COMPLETE
  totalQuestions        Int?
  overallScore          Float?                   // 0-100
  avgAnswerScore        Float?                   // 0-100
  starUsed              Int?                     // count of STAR-structured answers
  topSkill              String?
  durationActual        Int?                     // actual mins taken
  confidenceScore       Float?                   // avg from expression snapshots
  dominantEmotion       String?
  behaviorSummary       Json?                    // { confident%, nervous%, neutral%, confused% }
  aiInsights            Json?                    // ["insight1", "insight2", "insight3"]
  reportPdfPath         String?                  // URL to generated PDF

  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  intern      Interns                @relation(fields: [internId], references: [id])
  questions   AIInterviewQuestion[]
  expressions AIInterviewExpression[]

  @@index([internId, status])
  @@map(name: "ai_interviews")
}

model AIInterviewQuestion {
  id             String   @id @unique @default(uuid())
  aiInterviewId  String
  questionNumber Int
  questionText   String
  questionType   String?  // BEHAVIORAL, TECHNICAL, SITUATIONAL, CLOSING
  answerText     String?
  answerScore    Float?   // 0-10
  starUsed       Boolean  @default(false)
  skillTested    String?
  aiFeedback     String?
  answeredAt     DateTime?
  createdAt      DateTime @default(now())

  aiInterview AIInterview @relation(fields: [aiInterviewId], references: [id])

  @@index([aiInterviewId, questionNumber])
  @@map(name: "ai_interview_questions")
}


model AIInterviewExpression {
  id              String            @id @unique @default(uuid())
  aiInterviewId   String
  questionId      String?           // which question was being answered at this moment
  emotion         ExpressionEmotion @default(NEUTRAL)
  confidenceScore Float             // 0-100
  timestamp       DateTime
  createdAt       DateTime          @default(now())

  aiInterview AIInterview @relation(fields: [aiInterviewId], references: [id])

  @@index([aiInterviewId])
  @@map(name: "ai_interview_expressions")
}


// ai Call =======================

enum AICallStatus {
  PENDING                 // waiting for nextCallAt
  CALLING                 // cron picked it up, actively dialing
  COMPLETED               // intern answered and finished the interview
  ALL_ATTEMPTS_EXHAUSTED  // 3 attempts made, none answered/completed
  FAILED                  // unexpected system error
}

enum AICallAttemptStatus {
  IN_PROGRESS         // call is live right now
  NOT_ANSWERED        // rang out, intern didn't pick up
  ANSWERED_COMPLETED  // picked up + finished all questions
  ANSWERED_DROPPED    // picked up but hung up before completing
  MACHINE_DETECTED    // voicemail/answering machine detected
  FAILED              // Twilio/technical error
}

model AICallQuestion {
  id        String   @id @unique @default(uuid())
  companyId String
  jobId     String?
  question  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  audioUrl  String?
  company   Company  @relation(fields: [companyId], references: [id])
  job       Job?     @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, jobId, isActive])
  @@map(name: "ai_call_questions")
}

model AICall {
  id                    String       @id @unique @default(uuid())
  internId              String
  jobId                 String
  companyId             String
  candidateManagementId String
  status                AICallStatus @default(PENDING)
  attemptNumber         Int          @default(0)
  nextCallAt            DateTime?
  allAttemptsExhausted  Boolean      @default(false)  // denormalized from status for composite index; always set together with status
  triggerScore          Float
  transcript            Json?
  callScore             Float?
  callSummary           String?

  intern              Interns             @relation(fields: [internId], references: [id])
  company             Company             @relation(fields: [companyId], references: [id])
  job                 Job                 @relation(fields: [jobId], references: [id])
  candidateManagement CandidateManagement @relation(fields: [candidateManagementId], references: [id])
  attempts            AICallAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([internId, status])
  @@index([companyId, status])
  @@index([candidateManagementId])
  @@index([nextCallAt, allAttemptsExhausted, status])
  @@map(name: "ai_calls")
}

model AICallAttempt {
  id            String              @id @unique @default(uuid())
  aiCallId      String
  attemptNumber Int
  callSid       String?
  status        AICallAttemptStatus @default(IN_PROGRESS)
  duration      Int?
  scheduledAt   DateTime
  answeredAt    DateTime?
  failReason    String?

  aiCall    AICall   @relation(fields: [aiCallId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([aiCallId, attemptNumber])
  @@index([aiCallId])
  @@index([callSid])
  @@map(name: "ai_call_attempts")
}